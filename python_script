import serial
import time
import psutil
# --- AYARLAR ---
# Ubuntu'da HC-05 bağlandığında genellikle /dev/rfcomm0 veya /dev/ttyUSB0 olmaktadır.
# Bağlantıdan sonra 'ls /dev/tty*' komutu ile kontrol edilebilmektedir.
SERIAL_PORT = '/dev/rfcomm0'
BAUD_RATE = 9600

def get_cpu_temp():
    # psutil ile termal sensörleri okunmaktadır
    temps = psutil.sensors_temperatures()

    # Ubuntu'da genellikle 'coretemp' veya 'cpu_thermal' başlığı altındadır
    if 'coretemp' in temps:
        return int(temps['coretemp'][0].current)
    elif 'cpu_thermal' in temps:
        return int(temps['cpu_thermal'][0].current)
    else:
        # Alternatif: Dosya sisteminden doğrudan oku
        with open("/sys/class/thermal/thermal_zone0/temp", "r") as f:
            temp = f.read()
            return int(int(temp) / 1000)

try:
    # Seri portu aç
    ser = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=1)
    print(f"Bağlantı başarılı: {SERIAL_PORT}")

    while True:
        temp = get_cpu_temp()

        # STM32'ye veriyi gönder (Örn: "42\n")
        # \n (newline) karakteri STM32 tarafında verinin bittiğini anlamak için kritiktir.
        data_to_send = f"{temp}\n"
        ser.write(data_to_send.encode('utf-8'))

        print(f"Gönderilen Sıcaklık: {temp}°C")

        time.sleep(2) # 2 saniyede bir güncelle

except serial.SerialException as e:
    print(f"Hata: Port açılamadı. {e}")
except KeyboardInterrupt:
    print("\nProgram durduruldu.")
finally:
    if 'ser' in locals() and ser.is_open:
        ser.close()
